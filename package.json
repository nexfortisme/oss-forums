{
  "name": "oss-forums",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun --env-file=../../.env --cwd apps/web dev",
    "dev:api": "bun --env-file=../../.env --cwd apps/api dev",
    "build:web": "bun --env-file=../../.env.production --cwd apps/web build",
    "build:api": "bun --env-file=../../.env.production --cwd apps/api build"
  },
  "devDependencies": {}
}
